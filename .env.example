# Required — add these to run the API and scripts

# OpenAI API key (used for text-embedding-3-small embeddings)
OPENAI_API_KEY=sk-your-key-here

# PostgreSQL connection string (database will be created by scripts/create_db if missing)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost:5432/scenario_rag

# Optional (defaults shown)
# APP_NAME=Scenario RAG API
# EMBEDDING_MODEL=text-embedding-3-small
# TOP_K_RETRIEVAL=3
# HYBRID_SEARCH=true   # Vector + Keyword search, merged with RRF
